# =============================================================================
# PrimeDownloader Bot — Configuration Template
# Copy this file to .env and fill in the values.
# TELEGRAM_BOT_TOKEN must be set as a Replit Secret, NOT in this file.
# =============================================================================

# --- REQUIRED SECRET (Replit Secrets → never commit this value) ---
# TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather

# --- PERSISTENT CONFIG (copy into .env and edit) ---
REQUIRED_CHANNEL=@your_channel
OWNER_ID=0
ADMIN_IDS=1

# --- OPTIONAL TUNING (defaults shown) ---
MAX_FILE_SIZE_MB=50
DOWNLOAD_TIMEOUT=300
RATE_LIMIT_SECONDS=10
MAX_CONCURRENT_DOWNLOADS=5
CACHE_TTL_SECONDS=86400
CACHE_MAX_SIZE=1000
BROADCAST_BATCH_SIZE=30
