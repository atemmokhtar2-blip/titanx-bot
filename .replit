modules = ["python-3.12", "nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH python3 /home/runner/workspace/extracted_project/control_panel/server.py"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PrimeDownloader Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Support Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Developer Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TitanX Control Panel"

[[workflows.workflow]]
name = "PrimeDownloader Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 python3 /home/runner/workspace/extracted_project/bot.py"

[[workflows.workflow]]
name = "Support Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 python3 /home/runner/workspace/extracted_project/support_bot/bot.py"

[[workflows.workflow]]
name = "Admin Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 python3 /home/runner/workspace/extracted_project/admin_bot/bot.py"

[[workflows.workflow]]
