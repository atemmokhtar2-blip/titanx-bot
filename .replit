modules = ["python-3.12", "nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "/home/runner/workspace/scripts/deploy.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PrimeDownloader Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Support Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TitanX Control Panel"

[[workflows.workflow]]
name = "PrimeDownloader Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/extracted_project && PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH /home/runner/workspace/.pythonlibs/bin/python3 bot.py"

[[workflows.workflow]]
name = "Support Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/extracted_project && PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH /home/runner/workspace/.pythonlibs/bin/python3 support_bot/bot.py"

[[workflows.workflow]]
name = "TitanX Control Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/scripts/start.sh"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3002

[userenv]

[userenv.shared]
OWNER_ID = "7631249810"
ADMIN_IDS = "7631249810"
SUPPORT_BOT_USERNAME = "x_support_team_bot"
ADMIN_BOT_USERNAME = "x_admin_dev_bot"
REQUIRED_CHANNEL = "@Sounnnd"
PORT = "8080"

[nix]
packages = ["cargo", "ffmpeg-full", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "zip", "zlib"]
channel = "stable-25_05"
