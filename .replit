modules = ["python-3.12", "nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH python3 /home/runner/workspace/extracted_project/control_panel/server.py"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PrimeDownloader Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Support Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TitanX Control Panel"

[[workflows.workflow]]
name = "PrimeDownloader Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/extracted_project && PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH python3 bot.py"

[[workflows.workflow]]
name = "Support Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/extracted_project && PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH python3 support_bot/bot.py"

[[workflows.workflow]]
name = "TitanX Control Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace/.pythonlibs/lib/python3.12/site-packages:$PYTHONPATH python3 /home/runner/workspace/extracted_project/control_panel/server.py"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[userenv]

[userenv.shared]
OWNER_ID = "7631249810"
ADMIN_IDS = "7631249810"
SUPPORT_BOT_USERNAME = "x_support_team_bot"
ADMIN_BOT_USERNAME = "x_admin_dev_bot"
REQUIRED_CHANNEL = "@Sounnnd"

[nix]
packages = ["cargo", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "zip", "zlib"]
channel = "stable-25_05"
